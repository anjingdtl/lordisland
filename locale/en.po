# === Dialogues ===
# npc_town_chief_intro
msgid "tc_intro_1"
msgstr "Brave one, thank you for your help. Recently, monsters have appeared in the cave outside the village..."

msgid "tc_intro_2"
msgstr "One of our young people went missing there. Would you go look for them?"

msgid "choice_tc_yes"
msgstr "Yes, I'll go"

msgid "choice_tc_no"
msgstr "Let me ask around first"

msgid "tc_intro_3"
msgstr "Wonderful! Be careful of those monsters."

msgid "tc_intro_4"
msgstr "The cave is southeast of the village."

# npc_ehto_intro
msgid "ehto_intro_1"
msgstr "Thank you for rescuing me, brave one."

msgid "ehto_intro_2"
msgstr "Who are you...?"

msgid "choice_a"
msgstr "I'm Parn, a knight"

msgid "choice_b"
msgstr "Just passing by"

msgid "ehto_intro_3"
msgstr "I see. Indeed a brave knight."

msgid "ehto_intro_4"
msgstr "Then thank you as well."

