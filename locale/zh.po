# === Dialogues ===
# npc_town_chief_intro
msgid "tc_intro_1"
msgstr "勇者啊，感谢你愿意帮助我们。最近村外洞窟里有怪物出没..."

msgid "tc_intro_2"
msgstr "我们有个年轻人在那里失踪了，你愿意去找找看吗？"

msgid "choice_tc_yes"
msgstr "愿意，我去"

msgid "choice_tc_no"
msgstr "我先问问情况"

msgid "tc_intro_3"
msgstr "太好了！小心那些怪物。"

msgid "tc_intro_4"
msgstr "那个洞窟在村外东南方向。"

# npc_ehto_intro
msgid "ehto_intro_1"
msgstr "感谢你救了我，勇者。"

msgid "ehto_intro_2"
msgstr "请问你是……？"

msgid "choice_a"
msgstr "我叫帕恩，是个骑士"

msgid "choice_b"
msgstr "我只是路过"

msgid "ehto_intro_3"
msgstr "原来如此，果然是名勇敢的骑士。"

msgid "ehto_intro_4"
msgstr "那也谢谢你。"

